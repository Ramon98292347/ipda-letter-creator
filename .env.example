VITE_PORT=8080
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Opcional (novo formato Supabase). Se usar, pode deixar VITE_SUPABASE_ANON_KEY vazio.
VITE_SUPABASE_PUBLISHABLE_KEY=

# Observacao:
# - Nunca commitar o arquivo .env real com segredos.
# - No deploy da Vercel, configure essas variaveis em:
#   Project Settings -> Environment Variables.

# Segredos de Edge Functions (configurar no Supabase -> Edge Functions -> Secrets):
# USER_SESSION_JWT_SECRET=
# APP_RLS_JWT_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=
# CRON_SECRET=
# INTERNAL_KEY=
# ADMIN_KEY=
